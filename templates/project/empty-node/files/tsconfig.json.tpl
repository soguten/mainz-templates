{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["DOM", "ES2022"],
        "jsx": "react-jsx",
        "jsxImportSource": "mainz",
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "strict": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "types": []
    },
    "include": ["**/*.ts", "**/*.tsx"]
}
